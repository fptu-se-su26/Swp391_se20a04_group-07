# ============================================================
# SQL SERVER – thay bằng thông tin máy bạn
# ============================================================
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=SchoolBusDB
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ============================================================
# SERVER
# ============================================================
PORT=5000
NODE_ENV=development

# ============================================================
# SESSION SECRET (đổi thành chuỗi random dài)
# ============================================================
SESSION_SECRET=schoolbus_super_secret_key_2024

# ============================================================
# JWT SECRET
# ============================================================
JWT_SECRET=schoolbus_jwt_secret_2024
JWT_EXPIRES_IN=7d

# ============================================================
# GOOGLE OAUTH
# Lấy tại: https://console.cloud.google.com
# ============================================================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ============================================================
# CLIENT URLs (để CORS)
# ============================================================
ADMIN_URL=http://localhost:3000
PARENT_URL=http://localhost:3001
